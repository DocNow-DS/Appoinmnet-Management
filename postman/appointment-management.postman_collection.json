{
  "info": {
    "_postman_id": "6edbc33f-9711-4a08-8369-2f0e81c6eadf",
    "name": "Appointment Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "cursor-agent"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Dev",
      "item": [
        {
          "name": "Seed Sample Appointment",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/dev/appointments/seed"
          }
        }
      ]
    },
    {
      "name": "Patient",
      "item": [
        {
          "name": "Create appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"startTime\": \"2026-03-30T10:00:00\",\n  \"durationMinutes\": 30,\n  \"consultationType\": \"ONLINE\",\n  \"notes\": \"Follow-up\"\n}"
            },
            "url": "{{baseUrl}}/api/patient/appointments"
          }
        },
        {
          "name": "List my appointments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments"
          }
        },
        {
          "name": "Get appointment",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}"
          }
        },
        {
          "name": "Cancel appointment",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}/cancel"
          }
        },
        {
          "name": "Reschedule appointment",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startTime\": \"2026-03-31T15:00:00\",\n  \"durationMinutes\": 30,\n  \"notes\": \"New slot\"\n}"
            },
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}/reschedule"
          }
        },
        {
          "name": "Accept doctor reschedule proposal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}/accept-doctor-proposal"
          }
        },
        {
          "name": "Delete appointment",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}"
          }
        }
      ]
    },
    {
      "name": "Doctor",
      "item": [
        {
          "name": "List appointments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Doctor-Id",
                "value": "{{doctorId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/doctor/appointments?status=PENDING",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "doctor",
                "appointments"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get appointment",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Doctor-Id",
                "value": "{{doctorId}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/doctor/appointments/{{appointmentId}}"
          }
        },
        {
          "name": "Action — ACCEPT",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Doctor-Id",
                "value": "{{doctorId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"ACCEPT\",\n  \"message\": \"Confirmed\"\n}"
            },
            "url": "{{baseUrl}}/api/doctor/appointments/{{appointmentId}}/action"
          }
        },
        {
          "name": "Action — DECLINE",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Doctor-Id",
                "value": "{{doctorId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"DECLINE\",\n  \"message\": \"Not available\"\n}"
            },
            "url": "{{baseUrl}}/api/doctor/appointments/{{appointmentId}}/action"
          }
        },
        {
          "name": "Action — REQUEST_RESCHEDULE",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Doctor-Id",
                "value": "{{doctorId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"REQUEST_RESCHEDULE\",\n  \"message\": \"Please pick this slot\",\n  \"proposedStartTime\": \"2026-03-30T11:00:00\",\n  \"proposedEndTime\": \"2026-03-30T11:30:00\"\n}"
            },
            "url": "{{baseUrl}}/api/doctor/appointments/{{appointmentId}}/action"
          }
        },
        {
          "name": "Mark completed",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "X-Doctor-Id",
                "value": "{{doctorId}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/doctor/appointments/{{appointmentId}}/complete"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "jwtToken",
      "value": "",
      "description": "Bearer JWT for authenticated patient"
    },
    {
      "key": "patientId",
      "value": "your-patient-profile-id"
    },
    {
      "key": "doctorId",
      "value": "your-doctor-profile-id"
    },
    {
      "key": "appointmentId",
      "value": "paste-mongo-id-after-create"
    }
  ]
}
