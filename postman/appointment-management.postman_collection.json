{
  "info": {
    "_postman_id": "6edbc33f-9711-4a08-8369-2f0e81c6eadf",
    "name": "Appointment Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "cursor-agent"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Dev",
      "item": [
        {
          "name": "Seed Sample Appointment",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/dev/appointments/seed"
          }
        }
      ]
    },
    {
      "name": "Booking",
      "item": [
        {
          "name": "List doctors for booking",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/patient/booking/doctors"
          }
        },
        {
          "name": "List doctors by specialty",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patient/booking/doctors?specialty=Cardiology",
              "host": ["{{baseUrl}}"],
              "path": ["api", "patient", "booking", "doctors"],
              "query": [{ "key": "specialty", "value": "Cardiology" }]
            }
          }
        }
      ]
    },
    {
      "name": "Patient",
      "item": [
        {
          "name": "Create appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"startTime\": \"2026-03-30T10:00:00\",\n  \"durationMinutes\": 30,\n  \"consultationType\": \"ONLINE\",\n  \"notes\": \"Follow-up\"\n}"
            },
            "url": "{{baseUrl}}/api/patient/appointments"
          }
        },
        {
          "name": "List my appointments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments"
          }
        },
        {
          "name": "Get appointment",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}"
          }
        },
        {
          "name": "Cancel appointment",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}/cancel"
          }
        },
        {
          "name": "Reschedule appointment",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startTime\": \"2026-03-31T15:00:00\",\n  \"durationMinutes\": 30,\n  \"notes\": \"New slot\"\n}"
            },
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}/reschedule"
          }
        },
        {
          "name": "Accept doctor reschedule proposal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}/accept-doctor-proposal"
          }
        },
        {
          "name": "Delete appointment",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/patient/appointments/{{appointmentId}}"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "jwtToken",
      "value": "",
      "description": "Bearer JWT for authenticated patient"
    },
    {
      "key": "patientId",
      "value": "your-patient-profile-id"
    },
    {
      "key": "doctorId",
      "value": "your-doctor-profile-id"
    },
    {
      "key": "appointmentId",
      "value": "paste-mongo-id-after-create"
    }
  ]
}
